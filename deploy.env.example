# 复制为 deploy.env 后填写，与 docker-compose.prod.yml 一起使用：
#   docker compose --env-file deploy.env -f docker-compose.prod.yml up -d --build

# 必填：DeepSeek（或你在 backend 里配置的）API Key
DEEPSEEK_API_KEY=sk-your-key-here

# 可选：监听端口（默认 80）
HTTP_PORT=80

# 可选：LLM 厂商
# LLM_PROVIDER=deepseek

# 若前端通过独立域名访问、且 API 单独暴露时需配 CORS；使用本仓库 Nginx 同域反代时通常可不改
# CORS_ORIGINS=https://你的域名
